# ============================================================
# Site de Acolhimento FAESA — .gitignore
# ============================================================

# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# --- Ambiente / segredos ---
.env
.env.*
!.env.example

# --- Build ---
dist/
build/
coverage/
.cache/
.tmp/

# --- LaTeX (artefatos de compilação) ---
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb
*.dvi
# Mantém o .pdf principal versionado se necessário; comente a linha abaixo se versionar:
# *.pdf

# --- Editor / IDE ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
.idea/
*.swp

# --- OS ---
.DS_Store
Thumbs.db

# --- Subprojeto Prisma (modelagem isolada) ---
banco-dados-requisitos-projeto/node_modules/
banco-dados-requisitos-projeto/dev.db
banco-dados-requisitos-projeto/dev.db-journal
banco-dados-requisitos-projeto/.env

# --- Auditoria infra (não versionar) ---
infra-audit-*.txt
