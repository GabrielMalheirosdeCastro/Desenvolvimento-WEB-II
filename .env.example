# ============================================================
# Site de Acolhimento FAESA — variáveis de ambiente
# Copie este arquivo para `.env` (NUNCA versione o .env real).
# ============================================================

# --- Aplicação (página Em Construção) ---
NODE_ENV=development
PORT=3010
HOST=0.0.0.0

# --- Deploy EasyPanel ---
# Webhook de implantação configurado no EasyPanel (tratar como SEGREDO).
# Em produção/CI, use GitHub Secret `EASYPANEL_DEPLOY_WEBHOOK` em vez deste arquivo.
EASYPANEL_DEPLOY_WEBHOOK=https://vps.gmcsistemas.com.br/api/deploy/REPLACE_ME

# ============================================================
# As variáveis abaixo só serão usadas quando a aplicação real
# (Next.js + Prisma + Supabase) começar a ser desenvolvida.
# Mantidas aqui como contrato esperado.
# ============================================================

# --- Banco de dados (Supabase self-hosted na VPS) ---
# Em desenvolvimento (Windows 11), abra um túnel SSH antes:
#   ssh -L 5432:supabase-db:5432 -L 6543:supabase-pooler:6543 root@vps.gmcsistemas.com.br -N
# Depois aponte para localhost:
#   DATABASE_URL=postgresql://postgres.gmc:SENHA@localhost:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres:SENHA@localhost:5432/postgres
#
# Em produção (container rodando na rede overlay `easypanel`):
#   DATABASE_URL=postgresql://postgres.gmc:SENHA@supabase-pooler:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres:SENHA@supabase-db:5432/postgres
DATABASE_URL=
DIRECT_URL=

# --- Supabase (REST/Auth/Realtime/Storage via Kong) ---
SUPABASE_URL=https://api.gmcsistemas.com.br
SUPABASE_ANON_KEY=
# NUNCA use no frontend. Apenas no backend confiável.
SUPABASE_SERVICE_ROLE_KEY=
